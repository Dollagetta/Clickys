{
  "id": "pinterest_grid",
  "type": "SharedSlice",
  "name": "PinterestGrid",
  "description": "A masonry Pinterest-style grid for products including video support and modal details.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "s39ke",
      "description": "Default",
      "primary": {
        "heading": {
          "type": "Text",
          "config": {
            "label": "Heading",
            "placeholder": "Our Trending Products"
          }
        },
        "products": {
          "type": "Group",
          "config": {
            "label": "Products",
            "fields": {
              "product_title": {
                "type": "Text",
                "config": {
                  "label": "Product Title",
                  "placeholder": "Classic Wrist Watch"
                }
              },
              "description": {
                "type": "RichText",
                "config": {
                  "label": "Description",
                  "multi": "paragraph,em,strong,hyperlink",
                  "placeholder": "Add product details here..."
                }
              },
              "product_image": {
                "type": "Image",
                "config": {
                  "label": "Product Image",
                  "constraint": {},
                  "thumbnails": []
                }
              },
              "video_url": {
                "type": "Link",
                "config": {
                  "label": "Video URL",
                  "select": "media"
                }
              },
              "is_video": {
                "type": "Boolean",
                "config": {
                  "label": "Is Video",
                  "default_value": false
                }
              },
              "site_name": {
                "type": "Text",
                "config": {
                  "label": "Site Name",
                  "placeholder": "via Clickys.in"
                }
              },
              "affiliate_link": {
                "type": "Link",
                "config": {
                  "label": "Affiliate Link",
                  "placeholder": ""
                }
              },
              "aspect_ratio": {
                "type": "Select",
                "config": {
                  "label": "Aspect Ratio",
                  "default_value": "portrait",
                  "options": [
                    "square",
                    "portrait",
                    "tall",
                    "landscape"
                  ]
                }
              }
            }
          }
        }
      },
      "items": {}
    }
  ]
}
