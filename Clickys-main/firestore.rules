rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidSubscriber(data) {
      return data.keys().hasAll(['email', 'subscribedAt', 'isActive']) &&
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 200 && data.email.matches('^[^@]+@[^@]+\\.[a-zA-Z]{2,}$') &&
             data.isActive is bool &&
             data.subscribedAt == request.time;
    }

    match /subscribers/{subscriberId} {
      // Allow anybody (even anonymous) to subscribe, but they must provide perfectly formatted data.
      allow create: if isValidSubscriber(request.resource.data);
      // Reads, updates, and deletes are disabled to protect subscriber privacy and prevent tampering.
    }
  }
}
