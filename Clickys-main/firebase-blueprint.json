{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "A user subscribed to the email newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The subscriber's email address."
        },
        "subscribedAt": {
          "type": "timestamp",
          "description": "When the user subscribed."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the subscription is active."
        }
      },
      "required": ["email", "subscribedAt", "isActive"]
    }
  },
  "firestore": {
    "/subscribers/{subscriberId}": {
      "schema": {
        "$ref": "#/entities/Subscriber"
      },
      "description": "Collection of all newsletter subscribers."
    }
  }
}
